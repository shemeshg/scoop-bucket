{
    "version": "2.26.0",
    "description": "MidiRouterClient CLI – headless Midi Router Client service",
    "homepage": "https://github.com/shemeshg/MidiRouterClient",
    "license": "MIT",
    "depends": [
        "vcredist2022"
    ],

    "architecture": {
        "64bit": {
            "url": "https://downloads.sourceforge.net/midi-router-client/midi-router-client-cli-2.26.0-win64.zip",
            "hash": "186c4913d3290ecdcf1caf61440104dd69bb939da8c59215b69c4fcc0e9a3cb4"
        },
        "arm64": {
            "url": "https://downloads.sourceforge.net/midi-router-client/midi-router-client-cli-2.26.0-win64-ARM.zip",
            "hash": "c3d536af750e20f61720ed395bf929ff6226e3f245e0948b9abd40c1c0df5a35"
        }
    },

    "pre_install": [
        "if (!$global) { error 'This app MUST be installed globally. Use: scoop install -g <manifest>'; break }",
        "if (!([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) { error 'Elevation required. Run PowerShell as Administrator.'; break }",     
        "Get-ChildItem \"$dir\" -Recurse | Unblock-File",
        "sc.exe stop MidiRouterClientCli 2>$null",
        "sc.exe delete MidiRouterClientCli 2>$null"
    ],

    "post_install": [
        "$exe = Get-ChildItem \"$dir\\*\\bin\\midi-router-client-cli.exe\" | Select-Object -First 1",
        "sc.exe create MidiRouterClientCli binPath= \"$($exe.FullName)\" obj= \"LocalSystem\" start= demand"
    ],

    "pre_uninstall": [
        "sc.exe stop MidiRouterClientCli 2>$null",
        "sc.exe delete MidiRouterClientCli 2>$null"
    ],

    "bin": [
        "*\\bin\\midi-router-client-cli.exe"
    ],

    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.sourceforge.net/midi-router-client/midi-router-client-cli-$version-win64.zip"
            },
            "arm64": {
                "url": "https://downloads.sourceforge.net/midi-router-client/midi-router-client-cli-$version-win64-ARM.zip"
            }
        }
    }
}
