{
    "version": "2.40.0",
    "description": "MidiRouterClient CLI - headless Midi Router Client service",
    "homepage": "https://github.com/shemeshg/MidiRouterClient",
    "license": "MIT",

    "depends": [
        "vcredist2022"
    ],

    "architecture": {
        "64bit": {
            "url": "https://downloads.sourceforge.net/midi-router-client/midi-router-client-cli-2.40.0-win64.zip",
            "hash": "fb3428bae2ad25662613c30b5f6d247ade11b0f7aaebf2533a69e33e6eae1432"
        },
        "arm64": {
            "url": "https://downloads.sourceforge.net/midi-router-client/midi-router-client-cli-2.40.0-win64-ARM.zip",
            "hash": "ece98e09d6ce5fab78d7a4b8c30d5ab31d5cffcc0cc744967b8143f885c3c7c0"
        }
    },

    "pre_install": [
        "if (!$global) { error 'This app MUST be installed globally. Use: scoop install -g <manifest>'; break }",
        "if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) { error 'Elevation required. Run PowerShell as Administrator.'; break }",
        "Get-ChildItem \"$dir\" -Recurse | Unblock-File",
        "$svc = Get-Service MidiRouterClientCli -ErrorAction SilentlyContinue",
        "if ($svc) { sc.exe stop MidiRouterClientCli 2>$null }"
    ],

    "post_install": [
        "$exe = Get-ChildItem \"$dir\\*\\bin\\midi-router-client-cli.exe\" | Select-Object -First 1",
        "$svc = Get-WmiObject Win32_Service -Filter \"Name='MidiRouterClientCli'\" -ErrorAction SilentlyContinue",
        "if ($svc -and ($svc.PathName -ne $exe.FullName)) { sc.exe delete MidiRouterClientCli 2>$null }",
        "if (-not $svc -or ($svc.PathName -ne $exe.FullName)) { sc.exe create MidiRouterClientCli binPath= \"$($exe.FullName)\" obj= \"LocalSystem\" start= demand }"
    ],

    "pre_uninstall": [
        "sc.exe stop MidiRouterClientCli 2>$null",
        "sc.exe delete MidiRouterClientCli 2>$null"
    ],

    "bin": [
        "*\\bin\\midi-router-client-cli.exe"
    ],

    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.sourceforge.net/midi-router-client/midi-router-client-cli-$version-win64.zip"
            },
            "arm64": {
                "url": "https://downloads.sourceforge.net/midi-router-client/midi-router-client-cli-$version-win64-ARM.zip"
            }
        }
    }
}
