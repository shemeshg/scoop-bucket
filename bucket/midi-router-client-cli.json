{
    "version": "2.25.0",
    "description": "MidiRouterClient CLI – headless Midi Router Client service",
    "homepage": "https://github.com/shemeshg/MidiRouterClient",
    "license": "MIT",
    "depends": "vcredist2022",

    "architecture": {
        "64bit": {
            "url": "https://downloads.sourceforge.net/midi-router-client/midi-router-client-cli-2.25.0-win64.zip",
            "hash": "57c619143ad961e3bc4bdae410af73f56a071a8903310908f1ccf7920f785fc6"
        },
        "arm64": {
            "url": "https://downloads.sourceforge.net/midi-router-client/midi-router-client-cli-2.25.0-win64-ARM.zip",
            "hash": "56b1b5633864f155f8dd50e173e77edef371c3c0c28a4dd356b76a5f3f836bec"
        }
    },

    "pre_install": [
        "Get-ChildItem \"$dir\" -Recurse | Unblock-File",
        "sc.exe stop MidiRouterClientCli 2>$null",
        "sc.exe delete MidiRouterClientCli 2>$null"
    ],

    "post_install": [
        "$exe = Get-ChildItem \"$dir\\*\\bin\\midi-router-client-cli.exe\" | Select-Object -First 1",
        "sc.exe create MidiRouterClientCli binPath= \"$($exe.FullName)\" obj= \"LocalSystem\" start= demand"
    ],

    "pre_uninstall": [
        "sc.exe stop MidiRouterClientCli 2>$null",
        "sc.exe delete MidiRouterClientCli 2>$null"
    ],

    "bin": [
        "*\\bin\\midi-router-client-cli.exe"
    ],

    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.sourceforge.net/midi-router-client/midi-router-client-cli-$version-win64.zip"
            },
            "arm64": {
                "url": "https://downloads.sourceforge.net/midi-router-client/midi-router-client-cli-$version-win64-ARM.zip"
            }
        }
    }
}
