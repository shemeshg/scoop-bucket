{
    "version": "1.0.25",
    "description": "Pass-Simple – GUI for pass cli util",
    "homepage": "https://sourceforge.net/projects/pass-simple/",
    "license": "MIT",
    "depends": "vcredist2022",

    "architecture": {
        "64bit": {
            "url": "https://downloads.sourceforge.net/pass-simple/pass-simple-1.0.25-win64.exe",
            "hash": "3303689191918F9FB6AFC780FDF033157BD3A061A37689E52CF6C135E39289F9"
        },
        "arm64": {
            "url": "https://downloads.sourceforge.net/pass-simple/pass-simple-1.0.25-win64-ARM.exe",
            "hash": "F35A181811AD5EAA303568E8910104BBC0CA9FE8B59970F5AA36BFCD332AE9D3"
        }
    },

    "installer": {
        "script": [
            "Start-Process \"$dir\\$fname\" \"/S /D=$dir\" -Wait"
        ]
    },

    "uninstaller": {
        "script": [
            "Start-Process \"$dir\\Uninstall.exe\" \"/S\" -Wait"
        ]
    },

    "bin": [
        "bin\\pass-simple.exe"
    ],

    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.sourceforge.net/pass-simple/pass-simple-$version-win64.exe"
            },
            "arm64": {
                "url": "https://downloads.sourceforge.net/pass-simple/pass-simple-$version-win64-ARM.exe"
            }
        }
    }
}
